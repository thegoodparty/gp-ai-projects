# Campaign Plan Generator API Keys
# Copy this file to .env and add your actual API keys

# Tavily API Key (Required for community research)
# Get your key from: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Gemini API Key (Primary LLM provider)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# TogetherAI API Key (Fallback LLM provider - Optional)
# Get your key from: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your_together_api_key_here
