# Copy this file to .env and fill in your API keys


# Gemini API Key (Primary LLM provider)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# TogetherAI API Key (Fallback LLM provider - optional)
# Get your key from: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your_together_api_key_here


TAVILY_API_KEY=your_tavily_api_key_here

# Environment setting for logging
# Use 'development' for debug logging, 'production' for minimal logging
ENVIRONMENT=development
