# Production Environment Configuration
environment = "prod"

# Custom Domain
custom_domain_name = "ai.goodparty.org"

# VPC Configuration (us-west-2)
vpc_id = "vpc-0763fa52c32ebcf6a"
public_subnet_ids = [
  "subnet-07984b965dabfdedc",  # us-west-2a public (10.0.0.0/22)
  "subnet-01c540e6428cdd8db"   # us-west-2b public (10.0.8.0/22)
]

# Lambda Configuration (from serve-message-api outputs)
serve_message_lambda_arn = "arn:aws:lambda:us-west-2:333022194791:function:serve-message-prod"
serve_message_lambda_function_name = "serve-message-prod"

# Authentication
# Copy this file to prod.tfvars and replace with your actual API key
# IMPORTANT: Use a different API key for production than development
api_key = "YOUR_PRODUCTION_API_KEY_HERE"

# AWS Resources (us-west-2)
certificate_arn = "arn:aws:acm:us-west-2:333022194791:certificate/877b533e-4a54-4a63-8ed4-55818f0d8d34"
route53_zone_id = "Z10392302OXMPNQLPO07K"
