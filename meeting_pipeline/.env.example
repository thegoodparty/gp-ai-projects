# Google Gemini (required — extraction and briefing generation)
GEMINI_API_KEY=

# Web search (required for discover stage)
# Serper is the primary search backend; Firecrawl maps/crawls candidate domains
# and verifies agenda PDFs.
SERPER_API_KEY=
FIRECRAWL_API_KEY=

# Databricks (required only for collect_haystaq_batch.py — constituent voter data)
DATABRICKS_SERVER_HOSTNAME=
DATABRICKS_HTTP_PATH=
DATABRICKS_API_KEY=

# Storage backend — only "s3" is supported
STORAGE_BACKEND=s3

# S3 bucket name — required when STORAGE_BACKEND=s3
S3_BUCKET=meeting-pipeline-dev

# AWS profile — uses default credentials if not set
# Run: aws sso login --profile goodparty
AWS_PROFILE=goodparty
