# API Keys
GEMINI_API_KEY=your_gemini_api_key_here

# Environment
ENVIRONMENT=development

# Runtime Options (can also be passed via CLI or docker-compose environment)
SKIP_CLUSTERING=false
DEBUG=true

# Docker Volume Mounts
LOCAL_DATA_DIR=./data
LOCAL_OUTPUT_DIR=./output

# Runtime Parameters (pass via CLI or docker-compose environment override)
# CAMPAIGN_NAME - Required: Pass via --campaign flag or CAMPAIGN_NAME env var
